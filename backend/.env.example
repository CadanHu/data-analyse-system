# =================================================================
# 🚀 DataPulse 后端环境变量 (Local Dev)
# =================================================================

# --- [必填] AI 模型 API 密钥 ---
DEEPSEEK_API_KEY=your_deepseek_key_here

# [可选] 多模型支持
OPENAI_API_KEY=sk-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
GOOGLE_API_KEY=AIza-xxxx

# --- [可选] 模型默认名称 ---
MODEL_NAME=deepseek-chat

# --- [数据库] 本地连接建议 ---
# 如果在本地直接运行 python main.py，请将主机名改为 localhost
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_SESSION_DATABASE=data_pulse_sessions

# --- [数据库] PostgreSQL 本地连接 ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=postgres

# --- [系统] 安全 ---
LOG_LEVEL=INFO
JWT_SECRET_KEY=your_secret_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- [可选] OCR 配置 (Baidu) ---
BAIDU_OCR_API_KEY=your_key
BAIDU_OCR_SECRET_KEY=your_secret
