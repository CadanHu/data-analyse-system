# =================================================================
# Data Anaylse System - 后端环境配置模板 (.env.example)
# =================================================================

# --- DeepSeek API 配置 ---
# 用于普通对话 (SQLAgent)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# 用于知识解析 (KnowledgeExtractionService)
LANGEXTRACT_API_KEY=your-deepseek-api-key-here
LANGEXTRACT_MODEL=deepseek-chat
LANGEXTRACT_BASE_URL=https://api.deepseek.com

# --- OCR & 深度解析配置 ---
# 百度云 OCR (用于图片解析)
BAIDU_QIANFAN_API_KEY=your-baidu-bce-v3-token-here
# MinerU API (用于复杂 PDF/文档的深度解析)
MINERU_API_KEY=your-mineru-jwt-token-here

# --- 业务数据库配置 (MySQL) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=your_business_db
MYSQL_USER=root
MYSQL_PASSWORD=root

# --- 会话数据库配置 (存储对话历史) ---
USE_MYSQL_FOR_SESSIONS=true
MYSQL_SESSION_DATABASE=data_pulse_sessions

# --- 知识库向量数据库配置 (PostgreSQL / ChromaDB) ---
# 系统默认使用 ChromaDB (本地目录)，如需集成 PostgreSQL 请配置以下项
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_base
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- 邮件通知配置 (SMTP) ---
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password-here

# --- 安全配置 ---
SECRET_KEY=generate-a-strong-random-key-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
