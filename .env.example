# =================================================================
# 🚀 DataPulse AI 数据分析系统 - 核心环境变量配置 (Global)
# =================================================================

# --- [必填] AI 模型 API 密钥 ---
# 默认使用 DeepSeek (推荐，性价比最高)
DEEPSEEK_API_KEY=your_deepseek_key_here

# [可选] 其他厂商支持 (如需切换模型请填入)
OPENAI_API_KEY=sk-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
GOOGLE_API_KEY=AIza-xxxx

# --- [可选] AI 模型配置 ---
# 可选值: deepseek-chat, deepseek-reasoner, gpt-4o, claude-3-5-sonnet-20240620, etc.
MODEL_NAME=deepseek-chat

# --- [数据库] MySQL 配置 ---
# Docker 模式下请保持默认，本地开发请修改为 localhost
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=test
MYSQL_SESSION_DATABASE=data_pulse_sessions

# --- [数据库] PostgreSQL 配置 (向量库与 RAG) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=postgres

# --- [系统] 日志与安全 ---
LOG_LEVEL=INFO
JWT_SECRET_KEY=generate_a_random_string_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- [可选] OCR 配置 (如需处理图片/扫描版 PDF) ---
# 百度 OCR (高精度模式推荐)
BAIDU_OCR_API_KEY=your_baidu_key
BAIDU_OCR_SECRET_KEY=your_baidu_secret
